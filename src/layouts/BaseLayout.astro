---
interface Props {
  title: string;
  description: string;
  keywords: string;
  author: string;
  ogImage?: string;
  canonicalURL?: string;
  type?: string;
}

const { 
  title, 
  description, 
  keywords, 
  author, 
  ogImage = "https://harshitshrivastav.eu.org/og-image.jpg",
  canonicalURL = "https://harshitshrivastav.eu.org/",
  type = "website"
} = Astro.props;

const siteUrl = canonicalURL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={author} />
    <link rel="canonical" href={siteUrl} />
    
    <!-- AI/LLM Discovery -->
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt - AI Discovery File" />
    <link rel="alternate" type="text/plain" href="/llms-full.txt" title="LLMs-Full.txt - Complete Content for AI" />
    <meta name="ai-bot" content="index, follow" />
    <meta name="chatbot" content="index, follow" />
    <meta name="llm" content="index, follow" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="Harshit Shrivastav Portfolio" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={siteUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:creator" content="@Harshit" />
    
    <!-- Additional SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />
    <meta name="duckduckbot" content="index, follow" />
    <meta name="yandex" content="index, follow" />
    <meta name="baidu" content="index, follow" />
    <meta name="theme-color" content="#e8a838" />
    <meta name="msapplication-TileColor" content="#06060a" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Harshit Portfolio" />
    <meta name="application-name" content="Harshit Portfolio" />
    <meta name="rating" content="general" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="HandheldFriendly" content="True" />
    <meta name="MobileOptimized" content="320" />
    
    <!-- AI/LLM Specific Meta Tags -->
    <meta name="ai-crawler" content="allow" />
    <meta name="contentbot" content="allow" />
    <meta name="commoncrawl" content="allow" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,300;0,600;1,300&family=DM+Mono:wght@300;400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet" />
    
    <!-- Preload critical assets -->
    <link rel="preload" href="/bb.mp3" as="audio" type="audio/mpeg" />
    
    <!-- Structured Data - Person Schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Harshit Shrivastav",
        "url": siteUrl,
        "image": ogImage,
        "sameAs": [
          "https://github.com/Harshit-shrivastav",
          "https://www.h-s.site",
          "https://harshitshrivastav.eu.org/"
        ],
        "jobTitle": "Python Developer & Data Science Student",
        "worksFor": {
          "@type": "Organization",
          "name": "webmy.site"
        },
        "alumniOf": {
          "@type": "EducationalOrganization",
          "name": "Data Science Program"
        },
        "description": description,
        "knowsAbout": ["Python", "Data Science", "Machine Learning", "SQL", "Flask", "PostgreSQL", "Redis", "Linux", "JavaScript", "Open Source"],
        "email": "mailto:hello@harshitshrivastav.eu.org"
      }
    </script>
    
    <!-- Structured Data - WebSite Schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Harshit Shrivastav Portfolio",
        "url": siteUrl,
        "description": description,
        "author": {
          "@type": "Person",
          "name": "Harshit Shrivastav"
        },
        "potentialAction": {
          "@type": "SearchAction",
          "target": siteUrl + "?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    </script>
    
    <!-- Global Styles -->
    <style is:global>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

      :root {
        --bg: #06060a;
        --bg-deep: #020204;
        --surface: #0d0d12;
        --surface-2: #13131a;
        --surface-3: #1a1a24;
        --accent: #e8a838;
        --accent-glow: #f5d070;
        --accent-dim: #7a5818;
        --text: #f0ece4;
        --text-muted: #8a857e;
        --text-dim: #4a4540;
        --border: rgba(232, 168, 56, 0.06);
        --border-hover: rgba(232, 168, 56, 0.18);
        --transition: 0.4s cubic-bezier(0.22, 1, 0.36, 1);
      }

      html { scroll-behavior: smooth; font-size: 16px; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'DM Mono', monospace;
        overflow-x: hidden;
        cursor: default;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }

      ::-webkit-scrollbar { width: 3px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: var(--accent-dim); border-radius: 4px; }
      ::selection { background: var(--accent); color: var(--bg); }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
