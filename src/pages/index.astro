    // Project canvases
    function initProjectCanvas(canvasId, type) {
      const c = document.getElementById(canvasId);
      if (!c) return;
      const cx = c.getContext('2d');
      function resize() {
        c.width = c.parentElement.offsetWidth;
        c.height = c.parentElement.offsetHeight;
      }
      resize();
      if (type === 'grid') {
        let t = 0;
        function draw() {
          t += 0.008;
          cx.clearRect(0, 0, c.width, c.height);
          const spacing = 28;
          cx.strokeStyle = 'rgba(232,168,56,0.04)';
          cx.lineWidth = 0.5;
          for (let x = 0; x < c.width; x += spacing) {
            const offset = Math.sin(t + x * 0.008) * 2;
            cx.beginPath();
            cx.moveTo(x, 0);
            cx.lineTo(x + offset, c.height);
            cx.stroke();
          }
          for (let y = 0; y < c.height; y += spacing) {
            const offset = Math.cos(t + y * 0.008) * 2;
            cx.beginPath();
            cx.moveTo(0, y);
            cx.lineTo(c.width, y + offset);
            cx.stroke();
          }
          for (let x = spacing; x < c.width; x += spacing * 2) {
            for (let y = spacing; y < c.height; y += spacing * 2) {
              const pulse = 1 + Math.sin(t * 1.5 + x * 0.015 + y * 0.015) * 0.6;
              cx.beginPath();
              cx.arc(x, y, pulse, 0, Math.PI * 2);
              cx.fillStyle = `rgba(232,168,56,${0.08 + pulse * 0.06})`;
              cx.fill();
            }
          }
          requestAnimationFrame(draw);
        }
        draw();
      } else if (type === 'waves') {
        let t = 0;
        function draw() {
          t += 0.015;
          cx.clearRect(0, 0, c.width, c.height);
          for (let i = 0; i < 6; i++) {
            cx.beginPath();
            cx.strokeStyle = `rgba(232,168,56,${0.03 + i * 0.012})`;
            cx.lineWidth = 0.8;
            for (let x = 0; x <= c.width; x += 2) {
              const y = c.height / 2 + Math.sin(x * 0.008 + t + i * 0.7) * (12 + i * 7) + Math.cos(x * 0.015 + t * 1.3) * 4;
              if (x === 0) cx.moveTo(x, y);
              else cx.lineTo(x, y);
            }
            cx.stroke();
          }
          requestAnimationFrame(draw);
        }
        draw();
      } else if (type === 'nodes') {
        const nodes = Array.from({ length: 24 }, () => ({
          x: Math.random() * 400,
          y: Math.random() * 200,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4,
          r: Math.random() * 1.8 + 0.8
        }));
        function draw() {
          cx.clearRect(0, 0, c.width, c.height);
          nodes.forEach(n => {
            n.x += n.vx; n.y += n.vy;
            if (n.x < 0 || n.x > c.width) n.vx *= -1;
            if (n.y < 0 || n.y > c.height) n.vy *= -1;
          });
          for (let i = 0; i < nodes.length; i++) {
            for (let j = i + 1; j < nodes.length; j++) {
              const dx = nodes[i].x - nodes[j].x;
              const dy = nodes[i].y - nodes[j].y;
              const d = Math.sqrt(dx * dx + dy * dy);
              if (d < 90) {
                cx.beginPath();
                cx.moveTo(nodes[i].x, nodes[i].y);
                cx.lineTo(nodes[j].x, nodes[j].y);
                cx.strokeStyle = `rgba(232,168,56,${(1 - d / 90) * 0.12})`;
                cx.lineWidth = 0.5;
                cx.stroke();
              }
            }
          }
          nodes.forEach(n => {
            cx.beginPath();
            cx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
            cx.fillStyle = 'rgba(232,168,56,0.25)';
            cx.fill();
          });
          requestAnimationFrame(draw);
        }
        draw();
      }
    }
    setTimeout(() => {
      initProjectCanvas('projCanvas1', 'grid');
      initProjectCanvas('projCanvas2', 'waves');
      initProjectCanvas('projCanvas3', 'nodes');
    }, 150);
  </script>
</BaseLayout>
