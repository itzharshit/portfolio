  <!-- All JavaScript -->
  <script>
    // ═══════════════════════════════════════════
    // BACKGROUND CANVAS — Floating Orbs + Mesh
    // ═══════════════════════════════════════════
    const bgCanvas = document.getElementById('bgCanvas');
    const ctx = bgCanvas.getContext('2d');
    let W, H;
    let mouse = { x: -9999, y: -9999 };

    function resizeBg() {
      W = bgCanvas.width = window.innerWidth;
      H = bgCanvas.height = window.innerHeight;
    }
    resizeBg();
    window.addEventListener('resize', resizeBg);

    // Orb class
    class Orb {
      constructor() { this.reset(); }
      reset() {
        this.x = Math.random() * W;
        this.y = Math.random() * H;
        this.radius = Math.random() * 120 + 60;
        this.vx = (Math.random() - 0.5) * 0.15;
        this.vy = (Math.random() - 0.5) * 0.12;
        this.baseOpacity = Math.random() * 0.04 + 0.015;
        this.pulseSpeed = Math.random() * 0.003 + 0.001;
        this.pulseOffset = Math.random() * Math.PI * 2;
        this.hueShift = Math.random() * 20 - 10;
      }
      update(t) {
        this.x += this.vx;
        this.y += this.vy;
        const dx = mouse.x - this.x;
        const dy = mouse.y - this.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 500 && dist > 0) {
          const force = (500 - dist) / 500 * 0.0008;
          this.vx += (dx / dist) * force;
          this.vy += (dy / dist) * force;
        }
        this.vx *= 0.998;
        this.vy *= 0.998;
        this.currentOpacity = this.baseOpacity * (0.6 + 0.4 * Math.sin(t * this.pulseSpeed + this.pulseOffset));
        if (this.x < -this.radius) this.x = W + this.radius;
        if (this.x > W + this.radius) this.x = -this.radius;
        if (this.y < -this.radius) this.y = H + this.radius;
        if (this.y > H + this.radius) this.y = -this.radius;
      }
      draw() {
        const grad = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, this.radius);
        const r = 232 + this.hueShift;
        const g = 168 + this.hueShift * 0.5;
        grad.addColorStop(0, `rgba(${r}, ${g}, 56, ${this.currentOpacity * 1.5})`);
        grad.addColorStop(0.4, `rgba(${r}, ${g}, 56, ${this.currentOpacity * 0.6})`);
        grad.addColorStop(1, `rgba(${r}, ${g}, 56, 0)`);
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();
      }
    }

    // Dot class
    class Dot {
      constructor() {
        this.x = Math.random() * W;
        this.y = Math.random() * H;
        this.vx = (Math.random() - 0.5) * 0.25;
        this.vy = (Math.random() - 0.5) * 0.2;
        this.radius = Math.random() * 1.2 + 0.3;
        this.opacity = Math.random() * 0.3 + 0.08;
        this.pulseSpeed = Math.random() * 0.015 + 0.005;
        this.pulseOffset = Math.random() * Math.PI * 2;
      }
      update(t) {
        this.x += this.vx;
        this.y += this.vy;
        const dx = this.x - mouse.x;
        const dy = this.y - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 180 && dist > 0) {
          const force = (180 - dist) / 180;
          this.vx += (dx / dist) * force * 0.08;
          this.vy += (dy / dist) * force * 0.08;
        }
        this.vx *= 0.995;
        this.vy *= 0.995;
        this.currentOpacity = this.opacity * (0.5 + 0.5 * Math.sin(t * this.pulseSpeed + this.pulseOffset));
        if (this.x < -30) this.x = W + 30;
        if (this.x > W + 30) this.x = -30;
        if (this.y < -30) this.y = H + 30;
        if (this.y > H + 30) this.y = -30;
      }
      draw() {
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(232, 168, 56, ${this.currentOpacity})`;
        ctx.fill();
      }
    }

    // Shooting star
    class ShootingStar {
      constructor() {
        this.x = Math.random() * W;
        this.y = Math.random() * H * 0.4;
        this.len = Math.random() * 80 + 50;
        this.speed = Math.random() * 7 + 4;
        this.angle = Math.PI / 5 + (Math.random() - 0.5) * 0.4;
        this.opacity = 0;
        this.maxOpacity = Math.random() * 0.4 + 0.2;
        this.phase = 'in';
      }
      update() {
        if (this.phase === 'in') {
          this.opacity = Math.min(this.maxOpacity, this.opacity + 0.025);
          if (this.opacity >= this.maxOpacity) this.phase = 'out';
        } else {
          this.opacity -= 0.012;
        }
        this.x += Math.cos(this.angle) * this.speed;
        this.y += Math.sin(this.angle) * this.speed;
      }
      draw() {
        if (this.opacity <= 0) return;
        const tailX = this.x - Math.cos(this.angle) * this.len;
        const tailY = this.y - Math.sin(this.angle) * this.len;
        const grad = ctx.createLinearGradient(tailX, tailY, this.x, this.y);
        grad.addColorStop(0, `rgba(232, 168, 56, 0)`);
        grad.addColorStop(1, `rgba(245, 208, 112, ${this.opacity})`);
        ctx.beginPath();
        ctx.moveTo(tailX, tailY);
        ctx.lineTo(this.x, this.y);
        ctx.strokeStyle = grad;
        ctx.lineWidth = 1.5;
        ctx.stroke();
        const headGrad = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, 8);
        headGrad.addColorStop(0, `rgba(245, 208, 112, ${this.opacity * 0.6})`);
        headGrad.addColorStop(1, `rgba(232, 168, 56, 0)`);
        ctx.beginPath();
        ctx.arc(this.x, this.y, 8, 0, Math.PI * 2);
        ctx.fillStyle = headGrad;
        ctx.fill();
      }
      isDead() { return this.opacity <= 0 && this.phase === 'out'; }
    }

    const orbs = [], dots = [], shootingStars = [];
    const orbCount = 8;
    const dotCount = Math.min(120, Math.floor((W * H) / 12000));

    for (let i = 0; i < orbCount; i++) orbs.push(new Orb());
    for (let i = 0; i < dotCount; i++) dots.push(new Dot());

    let frame = 0;
    function animate() {
      frame++;
      ctx.clearRect(0, 0, W, H);
      orbs.forEach(o => { o.update(frame); o.draw(); });
      for (let i = 0; i < dots.length; i++) {
        for (let j = i + 1; j < dots.length; j++) {
          const dx = dots[i].x - dots[j].x;
          const dy = dots[i].y - dots[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 110) {
            const alpha = (1 - dist / 110) * 0.06;
            ctx.beginPath();
            ctx.moveTo(dots[i].x, dots[i].y);
            ctx.lineTo(dots[j].x, dots[j].y);
            ctx.strokeStyle = `rgba(232, 168, 56, ${alpha})`;
            ctx.lineWidth = 0.4;
            ctx.stroke();
          }
        }
      }
      for (let i = 0; i < dots.length; i++) {
        const dx = dots[i].x - mouse.x;
        const dy = dots[i].y - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 220) {
          const alpha = (1 - dist / 220) * 0.1;
          ctx.beginPath();
          ctx.moveTo(dots[i].x, dots[i].y);
          ctx.lineTo(mouse.x, mouse.y);
          ctx.strokeStyle = `rgba(232, 168, 56, ${alpha})`;
          ctx.lineWidth = 0.4;
          ctx.stroke();
        }
      }
      dots.forEach(d => { d.update(frame); d.draw(); });
      if (frame % 100 === 0 && Math.random() > 0.3) shootingStars.push(new ShootingStar());
      shootingStars.forEach(s => { s.update(); s.draw(); });
      for (let i = shootingStars.length - 1; i >= 0; i--) {
        if (shootingStars[i].isDead()) shootingStars.splice(i, 1);
      }
      requestAnimationFrame(animate);
