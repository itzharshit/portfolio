---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Harshit Shrivastav - Python Developer & Data Science Student Portfolio"
  description="Portfolio of Harshit Shrivastav, a Python Developer and Data Science student with skills in Python, SQL, Machine Learning, Flask, and more. Explore projects, experience, and contact information."
  keywords="Harshit Shrivastav, Harshit, Python Developer, Data Science, Portfolio, Machine Learning, SQL, Flask, PostgreSQL, Redis, Linux, Open Source"
  author="Harshit Shrivastav"
>
  <!-- Background Canvas -->
  <canvas id="bgCanvas"></canvas>

  <!-- Saturn Cursor -->
  <div class="cursor-saturn" id="cursorSaturn">
    <div class="cursor-glow"></div>
    <div class="cursor-ring-inner"></div>
    <div class="cursor-ring-outer"></div>
    <div class="cursor-ring-middle"></div>
    <div class="cursor-planet"></div>
  </div>

  <!-- Big Bang Sound Effect -->
  <audio id="bigBangSound" preload="auto">
    <source src="https://cdn.pixabay.com/download/audio/2021/08/04/audio_0625c1539c.mp3?filename=explosion-6265.mp3" type="audio/mpeg">
    <source src="https://cdn.pixabay.com/download/audio/2022/03/10/audio_c8c8a73467.mp3?filename=explosion-20547.mp3" type="audio/mpeg">
  </audio>

  <style>
    /* ══════ FULL-PAGE BACKGROUND CANVAS ══════ */
    #bgCanvas {
      position: fixed;
      top: 0; left: 0;
      width: 100vw;
      height: 100vh;
      z-index: 0;
      pointer-events: none;
    }

    /* ══════ CURSOR GLOW ══════ */
    body {
      cursor: none;
    }

    /* Saturn cursor container */
    .cursor-saturn {
      position: fixed;
      pointer-events: none;
      z-index: 9999999;
      transform: translate(-50%, -50%);
      will-change: left, top;
      width: 60px;
      height: 60px;
    }

    /* Planet (center sphere) */
    .cursor-planet {
      position: absolute;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: linear-gradient(135deg, #f5d070 0%, #e8a838 40%, #b8860b 70%, #7a5818 100%);
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      z-index: 3;
      box-shadow: 
        inset -3px -3px 6px rgba(0,0,0,0.4),
        inset 2px 2px 4px rgba(255,255,255,0.3),
        0 0 15px rgba(232, 168, 56, 0.5),
        0 0 30px rgba(232, 168, 56, 0.3);
    }

    /* Saturn rings - multiple layers for realism */
    .cursor-ring-outer {
      position: absolute;
      width: 56px;
      height: 56px;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%) rotateX(70deg) rotateY(15deg);
      border-radius: 50%;
      background: conic-gradient(
        from 180deg,
        rgba(245, 208, 112, 0.8) 0deg,
        rgba(232, 168, 56, 0.6) 60deg,
        rgba(180, 140, 60, 0.4) 120deg,
        rgba(122, 88, 24, 0.2) 180deg,
        rgba(180, 140, 60, 0.4) 240deg,
        rgba(232, 168, 56, 0.6) 300deg,
        rgba(245, 208, 112, 0.8) 360deg
      );
      border: 3px solid rgba(232, 168, 56, 0.4);
      z-index: 2;
      box-shadow: 
        0 0 10px rgba(232, 168, 56, 0.4),
        inset 0 0 15px rgba(232, 168, 56, 0.2);
      animation: ringRevolve 8s linear infinite;
    }

    .cursor-ring-middle {
      position: absolute;
      width: 44px;
      height: 44px;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%) rotateX(70deg) rotateY(15deg);
      border-radius: 50%;
      background: conic-gradient(
        from 180deg,
        rgba(245, 208, 112, 0.9) 0deg,
        rgba(232, 168, 56, 0.7) 90deg,
        rgba(180, 140, 60, 0.5) 180deg,
        rgba(232, 168, 56, 0.7) 270deg,
        rgba(245, 208, 112, 0.9) 360deg
      );
      z-index: 4;
      box-shadow: 0 0 8px rgba(232, 168, 56, 0.5);
      animation: ringRevolve 6s linear infinite reverse;
    }

    .cursor-ring-inner {
      position: absolute;
      width: 32px;
      height: 32px;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%) rotateX(70deg) rotateY(15deg);
      border-radius: 50%;
      border: 2px solid rgba(245, 208, 112, 0.6);
      z-index: 1;
      box-shadow: 0 0 6px rgba(232, 168, 56, 0.6);
      animation: ringRevolve 4s linear infinite;
    }

    /* Crescent highlight on planet */
    .cursor-planet::after {
      content: '';
      position: absolute;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.4), transparent 60%);
      top: 2px;
      left: 2px;
    }

    /* Outer glow */
    .cursor-glow {
      position: absolute;
      width: 100px;
      height: 100px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(232,168,56,0.12) 0%, rgba(232,168,56,0.05) 25%, rgba(232,168,56,0.02) 50%, transparent 70%);
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      z-index: 0;
      filter: blur(15px);
      animation: pulse 3s ease-in-out infinite;
    }

    @keyframes ringTilt {
      0% { transform: translate(-50%, -50%) rotateX(70deg) rotateY(15deg) rotateZ(0deg); }
      50% { transform: translate(-50%, -50%) rotateX(70deg) rotateY(15deg) rotateZ(10deg); }
      100% { transform: translate(-50%, -50%) rotateX(70deg) rotateY(15deg) rotateZ(0deg); }
    }

    @keyframes ringRevolve {
      from { transform: translate(-50%, -50%) rotateX(70deg) rotateY(15deg) rotateZ(0deg); }
      to { transform: translate(-50%, -50%) rotateX(70deg) rotateY(15deg) rotateZ(360deg); }
    }

    @keyframes pulse {
      0%, 100% { opacity: 0.6; transform: translate(-50%, -50%) scale(1); }
      50% { opacity: 1; transform: translate(-50%, -50%) scale(1.1); }
    }

    /* Click effect */
    .cursor-saturn.clicked .cursor-planet {
      transform: translate(-50%, -50%) scale(0.85);
    }

    .cursor-saturn.clicked .cursor-ring-middle {
      transform: translate(-50%, -50%) rotateX(70deg) rotateY(15deg) scale(1.3);
      opacity: 0.8;
    }

    .cursor-saturn.clicked .cursor-ring-outer {
      transform: translate(-50%, -50%) rotateX(70deg) rotateY(15deg) scale(1.2);
    }

    .cursor-saturn.clicked .cursor-glow {
      transform: translate(-50%, -50%) scale(1.5);
      opacity: 1;
    }

    /* Hover effect on clickable elements */
    .cursor-saturn.hovering .cursor-planet {
      background: linear-gradient(135deg, #fff5e0 0%, #f5d070 40%, #e8a838 70%, #b8860b 100%);
      box-shadow: 
        inset -3px -3px 6px rgba(0,0,0,0.4),
        inset 2px 2px 4px rgba(255,255,255,0.5),
        0 0 25px rgba(232, 168, 56, 0.8),
        0 0 50px rgba(232, 168, 56, 0.5);
    }

    .cursor-saturn.hovering .cursor-ring-middle {
      box-shadow: 0 0 15px rgba(232, 168, 56, 0.8);
    }

    .cursor-saturn.hovering .cursor-glow {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1.2);
    }

    /* Ripple effect on click */
    .cursor-ripple {
      position: fixed;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      border: 2px solid var(--accent);
      pointer-events: none;
      z-index: 9998;
      transform: translate(-50%, -50%);
      animation: rippleExpand 0.6s ease-out forwards;
    }

    @keyframes rippleExpand {
      0% {
        width: 20px;
        height: 20px;
        opacity: 1;
        border-width: 3px;
      }
      100% {
        width: 120px;
        height: 120px;
        opacity: 0;
        border-width: 0px;
      }
    }

    /* ══════ NAVIGATION ══════ */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 0 clamp(20px, 4vw, 48px);
      height: 64px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      backdrop-filter: blur(24px) saturate(1.4);
      background: rgba(6,6,10,0.72);
      border-bottom: 1px solid var(--border);
      transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    }

    nav.hidden { transform: translateY(-100%); }

    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      letter-spacing: 0.18em;
      color: var(--accent);
      text-decoration: none;
      position: relative;
      padding: 4px 0;
    }

    .nav-logo::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      width: 100%; height: 1px;
      background: var(--accent);
      transform: scaleX(0);
      transform-origin: right;
      transition: transform var(--transition);
    }
    .nav-logo:hover::after { transform: scaleX(1); transform-origin: left; }

    .nav-links { display: flex; gap: 28px; list-style: none; }

    .nav-links a {
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      transition: color 0.3s;
    }

    .nav-links a::before {
      content: '//';
      margin-right: 4px;
      color: var(--text-dim);
      transition: color 0.3s;
    }
    .nav-links a:hover { color: var(--accent); }
    .nav-links a:hover::before { color: var(--accent-dim); }

    /* ══════ HERO ══════ */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      z-index: 2;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 1;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      opacity: 0.5;
    }

    /* Grid overlay */
    .hero-grid {
      position: absolute;
      inset: 0;
      z-index: 1;
      background-image:
        linear-gradient(rgba(232,168,56,0.015) 1px, transparent 1px),
        linear-gradient(90deg, rgba(232,168,56,0.015) 1px, transparent 1px);
      background-size: 80px 80px;
      mask-image: radial-gradient(ellipse 65% 55% at 50% 50%, black 10%, transparent 80%);
      -webkit-mask-image: radial-gradient(ellipse 65% 55% at 50% 50%, black 10%, transparent 80%);
      pointer-events: none;
    }

    .hero-content {
      text-align: center;
      z-index: 10;
      padding: 0 24px;
      position: relative;
    }

    .hero-eyebrow {
      font-size: 0.6rem;
      letter-spacing: 0.55em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 28px;
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 0.3s;
    }

    .hero-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(4.5rem, 13vw, 12rem);
      line-height: 0.88;
      letter-spacing: 0.02em;
      margin-bottom: 20px;
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 0.5s;
    }

    .hero-title .accent {
      background: linear-gradient(135deg, var(--accent-dim) 0%, var(--accent) 30%, var(--accent-glow) 60%, var(--accent) 100%);
      background-size: 200% 200%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmer 6s ease-in-out infinite;
    }

    @keyframes shimmer {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }

    .hero-subtitle {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1rem, 2.5vw, 1.5rem);
      font-weight: 300;
      font-style: italic;
      color: var(--text-muted);
      margin-bottom: 12px;
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 0.7s;
    }

    .hero-tagline {
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      color: var(--text-dim);
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 0.9s;
    }

    .hero-line {
      position: absolute;
      bottom: 100px;
      left: 50%;
      transform: translateX(-50%);
      width: 1px;
      height: 60px;
      background: linear-gradient(to bottom, var(--accent), transparent);
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 1.2s, lineGlow 3s ease-in-out infinite;
      z-index: 10;
    }

    @keyframes lineGlow {
      0%, 100% { opacity: 0.4; }
      50% { opacity: 0.8; }
    }

    .hero-scroll {
      position: absolute;
      bottom: 32px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 1.4s;
    }

    .hero-scroll span {
      font-size: 0.5rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--text-dim);
    }

    /* ══════ SECTIONS ══════ */
    section {
      position: relative;
      z-index: 2;
    }

    .section-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 140px clamp(20px, 5vw, 48px);
    }

    .section-label {
      font-size: 0.55rem;
      letter-spacing: 0.55em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 14px;
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .section-label::before {
      content: '';
      width: 32px;
      height: 1px;
      background: var(--accent-dim);
    }

    .section-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.8rem, 6vw, 5.5rem);
      letter-spacing: 0.02em;
      margin-bottom: 72px;
      line-height: 1;
    }

    /* ══════ MARQUEE ══════ */
    .marquee-wrapper {
      overflow: visible;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 18px 0;
      position: relative;
      z-index: 2;
      background: rgba(2,2,4,0.6);
      backdrop-filter: blur(8px);
    }

    .marquee {
      display: flex;
      gap: 56px;
      animation: marquee 35s linear infinite;
      width: max-content;
    }

    .marquee span {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.1rem;
      letter-spacing: 0.18em;
      color: var(--text-dim);
      white-space: nowrap;
    }

    .marquee .dot {
      color: var(--accent-dim);
      margin: 0 18px;
      font-size: 0.6rem;
    }

    @keyframes marquee {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }

    /* ══════ ABOUT ══════ */
    .about-grid {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 80px;
      align-items: start;
    }

    .about-text p {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.25rem;
      font-weight: 300;
      line-height: 1.85;
      color: var(--text-muted);
      margin-bottom: 20px;
    }

    .about-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-top: 48px;
    }

    .stat-card {
      padding: 28px 24px;
      border: 1px solid var(--border);
      background: rgba(13,13,18,0.8);
      backdrop-filter: blur(12px);
      position: relative;
      overflow: visible;
      transition: border-color var(--transition), transform 0.3s;
    }

    .stat-card:hover {
      border-color: var(--border-hover);
      transform: translateY(-2px);
    }

    .stat-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 2px;
      background: linear-gradient(90deg, var(--accent), transparent);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform var(--transition);
    }
    .stat-card:hover::before { transform: scaleX(1); }

    .stat-number {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.6rem;
      color: var(--accent);
      line-height: 1;
    }

    .stat-label {
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin-top: 10px;
    }

    /* ══════ TECH ══════ */
    .tech-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }

    .tech-card {
      padding: 36px 20px 28px;
      border: 1px solid var(--border);
      background: rgba(13,13,18,0.8);
      backdrop-filter: blur(12px);
      text-align: center;
      position: relative;
      overflow: visible;
      transition: all var(--transition);
    }

    .tech-card:hover {
      border-color: var(--border-hover);
      transform: translateY(-4px);
      box-shadow: 0 24px 64px rgba(232,168,56,0.04);
      background: rgba(19,19,26,0.9);
    }

    .tech-card-icon {
      font-size: 2.2rem;
      margin-bottom: 18px;
      display: block;
      filter: grayscale(1) brightness(0.7);
      transition: filter 0.5s;
    }
    .tech-card:hover .tech-card-icon { filter: grayscale(0) brightness(1); }

    .tech-card-name {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      margin-bottom: 6px;
    }

    .tech-card-cat {
      font-size: 0.55rem;
      color: var(--text-dim);
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    /* ══════ TIMELINE ══════ */
    .timeline {
      position: relative;
      padding-left: 56px;
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: 20px; top: 0; bottom: 0;
      width: 1px;
      background: linear-gradient(to bottom, var(--accent-dim), transparent);
    }

    .timeline-item {
      position: relative;
      margin-bottom: 48px;
      padding: 32px;
      border: 1px solid var(--border);
      background: rgba(13,13,18,0.8);
      backdrop-filter: blur(12px);
      transition: all var(--transition);
    }

    .timeline-item:last-child { margin-bottom: 0; }

    .timeline-item:hover {
      border-color: var(--border-hover);
      background: rgba(19,19,26,0.9);
    }

    .timeline-item::before {
      content: '';
      position: absolute;
      left: -44px; top: 38px;
      width: 9px; height: 9px;
      background: var(--accent);
      border-radius: 50%;
      box-shadow: 0 0 24px rgba(232,168,56,0.25);
      transition: box-shadow 0.3s;
    }
    .timeline-item:hover::before { box-shadow: 0 0 32px rgba(232,168,56,0.45); }

    .timeline-role {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1.05rem;
      margin-bottom: 4px;
    }

    .timeline-company {
      font-size: 0.7rem;
      color: var(--accent);
      letter-spacing: 0.12em;
      margin-bottom: 4px;
    }

    .timeline-date {
      font-size: 0.55rem;
      color: var(--text-dim);
      letter-spacing: 0.22em;
      text-transform: uppercase;
      margin-bottom: 18px;
    }

    .timeline-desc {
      font-size: 0.78rem;
      color: var(--text-muted);
      line-height: 1.75;
    }

    .timeline-desc li {
      margin-bottom: 6px;
      list-style: none;
      padding-left: 18px;
      position: relative;
    }

    .timeline-desc li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: var(--accent-dim);
    }

    /* ══════ EDUCATION ══════ */
    .edu-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .edu-card {
      padding: 40px 36px;
      border: 1px solid var(--border);
      background: rgba(13,13,18,0.8);
      backdrop-filter: blur(12px);
      position: relative;
      overflow: visible;
      transition: all var(--transition);
    }

    .edu-card:hover { border-color: var(--border-hover); }

    .edu-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      width: 100%; height: 2px;
      background: linear-gradient(90deg, var(--accent), transparent);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .edu-card:hover::after { transform: scaleX(1); }

    .edu-degree {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1.05rem;
      margin-bottom: 6px;
    }

    .edu-school {
      font-size: 0.7rem;
      color: var(--accent);
      letter-spacing: 0.12em;
      margin-bottom: 4px;
    }

    .edu-date {
      font-size: 0.55rem;
      color: var(--text-dim);
      letter-spacing: 0.22em;
      text-transform: uppercase;
      margin-bottom: 22px;
    }

    .edu-details { list-style: none; }

    .edu-details li {
      font-size: 0.75rem;
      color: var(--text-muted);
      padding: 7px 0 7px 18px;
      position: relative;
    }

    .edu-details li::before {
      content: '◇';
      position: absolute;
      left: 0;
      color: var(--accent-dim);
      font-size: 0.45rem;
      top: 10px;
    }

    /* ══════ PROJECTS ══════ */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .project-card {
      border: 1px solid var(--border);
      background: rgba(13,13,18,0.8);
      backdrop-filter: blur(12px);
      overflow: visible;
      position: relative;
      transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .project-card:hover {
      border-color: var(--border-hover);
      transform: translateY(-6px);
      box-shadow: 0 32px 80px rgba(232,168,56,0.05);
    }

    .project-visual {
      height: 180px;
      background: rgba(19,19,26,0.6);
      position: relative;
